      const select = document.getElementById('selectUserAdmin');
      select.innerHTML = '';
      
      const users = loadDaftarUserSistem();
      const userKeys = Object.keys(users);

      if (userKeys.length === 0) {
        const opt = document.createElement('option');
        opt.textContent = "Belum ada pengguna terdaftar";
        opt.value = "";
        select.appendChild(opt);
        activeDataScopeUser = null;
        loadData();
        renderDaftarPelanggan();
        return;
      }

      userKeys.forEach(k => {
        const opt = document.createElement('option');
        opt.value = users[k].usernameReal;
        opt.textContent = `Pengguna: ${users[k].usernameReal}`;
        select.appendChild(opt);
      });

      // Secara default memuat data dari pengguna pertama di daftar
      activeDataScopeUser = users[userKeys[0]].usernameReal;
      loadData();
      renderDaftarPelanggan();
    }

    function adminGantiTargetUser() {
      const select = document.getElementById('selectUserAdmin');
      if (select.value) {
        activeDataScopeUser = select.value;
        loadData();
        renderDaftarPelanggan();
        showToast(`📂 Memuat basis data milik: ${activeDataScopeUser}`);
      }
    }

    function adminHapusAkunTerpilih() {
      if (!activeDataScopeUser) return;
      if (!confirm(`⚠️ ADMIN MASTER CRITICAL ACTION:\nApakah Anda yakin ingin menghapus akun "${activeDataScopeUser}" BESERTA SELURUH DATA BONNYA? Tindakan ini tidak dapat dibatalkan.`)) return;

      const target = activeDataScopeUser;
      const users = loadDaftarUserSistem();
      const userKey = target.toLowerCase();

      if (users[userKey]) {
        delete users[userKey];
        simpanDaftarUserSistem(users);
      }

      // Bersihkan data objek lokal storage milik user target
      localStorage.removeItem(`bon_v15_data_${target}_semuaBon`);
      localStorage.removeItem(`bon_v15_data_${target}_pembayaran`);

      showToast(`🔥 Akun & database ${target} berhasil dimusnahkan!`);
      buildAdminDropdownUser();
    }

    // --- ⚡ FITUR ENGINE TAMBAHAN KHUSUS ADMIN MASTER v16 ⚡ ---
    
    // Fungsi Ekspor Seluruh Data Pelanggan yang Terpisah Otomatis Tiap Pelanggan
    function adminEksporDataTerpisah() {
      if (!activeDataScopeUser) {
        showToast("❌ Tidak ada database pengguna yang terpilih!", true);
        return;
      }
      try {
        const dataTerpisah = {
          versi: "BON-v16-ADMIN",
          targetUser: activeDataScopeUser,
          waktuEkspor: getFullTimestamp(),
          databasePelanggan: {}
        };

        // Kumpulkan daftar unik seluruh pelanggan di database scope terpilih
        const daftarPelangganSet = new Set();
        semuaBon.forEach(b => { if(b && b.namaPelanggan) daftarPelangganSet.add(b.namaPelanggan); });
        pembayaran.forEach(p => { if(p && p.namaPelanggan) daftarPelangganSet.add(p.namaPelanggan); });

        if (daftarPelangganSet.size === 0) {
          showToast("❌ Database kosong, tidak ada data pelanggan untuk diekspor.", true);
          return;
        }

        // Pisahkan data per pelanggan ke dalam objek terisolasi
        daftarPelangganSet.forEach(nama => {
          dataTerpisah.databasePelanggan[nama] = {
            semuaBon: semuaBon.filter(b => b && b.namaPelanggan === nama),
            pembayaran: pembayaran.filter(p => p && p.namaPelanggan === nama)
          };
        });

        const jsonStr = JSON.stringify(dataTerpisah, null, 2);
        const blob = new Blob([jsonStr], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `ADMIN-TERPISAH-${activeDataScopeUser}-${new Date().toISOString().slice(0,10)}.json`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        showToast("⚡ Seluruh data pelanggan berhasil dipisah dan diekspor!");
      } catch (e) {
        showToast("❌ Gagal mengekspor data terpisah.", true);
      }
    }

    // Fungsi Impor Data Terpisah / Massal / Satu Pelanggan untuk Admin Master
    function adminImporDataTerpisah(file) {
      if (!activeDataScopeUser) {
        showToast("❌ Pilih target user terlebih dahulu!", true);
        return;
      }
      if (!file || file.size > MAX_DATA_SIZE) {
        showToast("❌ File tidak valid atau terlalu besar.", true);
        return;
      }

      const reader = new FileReader();
      reader.onload = function(e) {
        try {
          const data = safeParseJSON(e.target.result);
          if (!data || typeof data !== 'object') throw new Error();
          
          // Deteksi apakah file JSON adalah format admin terpisah v16
          if (data.versi === "BON-v16-ADMIN" && data.databasePelanggan) {
            const listPelanggan = Object.keys(data.databasePelanggan);
            if (listPelanggan.length === 0) {
              showToast("❌ Tidak ditemukan data pelanggan di dalam file.", true);
              return;
            }

            const opsiPrompt = prompt(
              `📂 Ditemukan ${listPelanggan.length} data pelanggan.\n` +
              `Ketik 'SEMUA' untuk mengembalikan seluruh data pelanggan.\n` +
              `Atau ketik nama pelanggan secara spesifik untuk memulihkan satu data saja:\n\n` +
              `Daftar: ${listPelanggan.join(', ')}`
            );

            if (!opsiPrompt) return;

            if (opsiPrompt.trim().toUpperCase() === 'SEMUA') {
              // Pulihkan seluruh data pelanggan (Massal)
              if (!confirm("⚠️ Peringatan: Tindakan ini akan menggabungkan/menimpa data lama pelanggan. Lanjutkan?")) return;
              
              listPelanggan.forEach(nama => {
                const node = data.databasePelanggan[nama];
                // Hapus data lama pelanggan tersebut agar bersih sebelum di-restore
                semuaBon = semuaBon.filter(b => b.namaPelanggan !== nama);
                pembayaran = pembayaran.filter(p => p.namaPelanggan !== nama);

                if (Array.isArray(node.semuaBon)) semuaBon.push(...node.semuaBon.filter(isValidBon));
                if (Array.isArray(node.pembayaran)) pembayaran.push(...node.pembayaran.filter(isValidPembayaran));
              });
              
              if (simpanKeStorage()) {
                renderDaftarPelanggan();
                showToast("⚡ Sukses mengembalikan seluruh data pelanggan!");
              }
            } else {
              // Pulihkan pelanggan tunggal secara spesifik
              const targetNama = opsiPrompt.trim();
              const matchKey = listPelanggan.find(k => k.toLowerCase() === targetNama.toLowerCase());

              if (!matchKey) {
                showToast("❌ Nama pelanggan tidak terdaftar di file impor!", true);
                return;
              }

              const node = data.databasePelanggan[matchKey];
              // Bersihkan data lama khusus pelanggan terpilih
              semuaBon = semuaBon.filter(b => b.namaPelanggan !== matchKey);
              pembayaran = pembayaran.filter(p => p.namaPelanggan !== matchKey);

              if (Array.isArray(node.semuaBon)) semuaBon.push(...node.semuaBon.filter(isValidBon));
              if (Array.isArray(node.pembayaran)) pembayaran.push(...node.pembayaran.filter(isValidPembayaran));

              if (simpanKeStorage()) {
                renderDaftarPelanggan();
                showToast(`⚡ Data pelanggan "${matchKey}" berhasil dipulihkan!`);
              }
            }
          } else {
            showToast("❌ Format file tidak dikenali oleh system admin v16.", true);
          }
          document.getElementById('adminImporFile').value = '';
        } catch (err) {
          showToast("❌ Gagal memproses struktur file JSON.", true);
          document.getElementById('adminImporFile').value = '';
        }
      };
      reader.readAsText(file);
    }
    
    // === INIT APPLICATION v15 & v16 ===
    loadHiddenBarangMap();
  </script>
